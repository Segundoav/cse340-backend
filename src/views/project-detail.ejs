<%- include('partials/header') %>

<main class="container">
    <h1><%= project.project_name %></h1>

    <% if (locals.user && locals.user.role_name === 'admin') { %>
        <a href="/edit-project/<%= project.project_id %>">Edit Project</a> | 
        <a href="/assign-categories/<%= project.project_id %>">Update Categories</a>
    <% } %>

    <p><%= project.description %></p>

    <hr>

    <div class="project-categories">
        <h3>Categories:</h3>
        <% if (categories && categories.length > 0) { %>
            <% categories.forEach(category => { %>
                <a href="/category/<%= category.category_id %>" style="display: inline-block; background: #007acc; color: white; padding: 6px 12px; border-radius: 4px; text-decoration: none; margin-right: 8px; font-weight: bold; font-size: 0.9em;">
                    <%= category.category_name %>
                </a>
            <% }) %>
        <% } else { %>
            <p>No categories assigned to this project.</p>
        <% } %>
    </div>

    <hr>

    <!-- SECCIÓN DE VOLUNTARIADO -->
    <% if (locals.user) { %>
        <div class="volunteer-section">
            <% if (isVolunteer) { %>
                <p><strong>✅ You are volunteering for this project.</strong></p>
                <form action="/unvolunteer/<%= project.project_id %>" method="POST">
                    <button type="submit">Unvolunteer</button>
                </form>
            <% } else { %>
                <form action="/volunteer/<%= project.project_id %>" method="POST">
                    <button type="submit">Volunteer for this project</button>
                </form>
            <% } %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>