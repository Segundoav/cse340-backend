<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <p>Check out our current service projects below. We have many opportunities for you to get involved and help the cause.</p>

    <% if (locals.user && locals.user.role_name === 'admin') { %>
        <a href="/new-project">+ Add New Project</a>
    <% } %>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>" style="font-weight: bold; text-decoration: none;">
                    <%= project.project_name %>
                </a>
                : <%= project.description %>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>