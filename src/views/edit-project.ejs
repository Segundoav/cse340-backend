<%- include('partials/header') %>
<main class="container">
  <h1>Edit Project</h1>
  <% if (errors && errors.length > 0) { %>
    <ul class="error-list">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  <% } %>
  <form action="/edit-project/<%= project.project_id %>" method="POST" class="form-standard">
    <div class="form-group">
      <label for="project_name">Project Name:</label>
      <input type="text" id="project_name" name="project_name" value="<%= project.project_name %>" maxlength="150" required>
    </div>
    <div class="form-group">
      <label for="description">Description:</label>
      <textarea id="description" name="description" required><%= project.description %></textarea>
    </div>
    <input type="hidden" name="project_id" value="<%= project.project_id %>">
    <button type="submit" class="btn-primary">Update Project</button>
  </form>
</main>
<%- include('partials/footer') %>