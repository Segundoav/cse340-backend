<%- include('partials/header') %>
<main class="container">
  <h1>Create New Project</h1>
  <% if (errors && errors.length > 0) { %>
    <ul class="error-list">
      <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
    </ul>
  <% } %>
  <form action="/new-project" method="POST" class="form-standard">
    <div class="form-group">
      <label for="project_name">Project Name:</label>
      <input type="text" id="project_name" name="project_name" value="<%= locals.project_name || '' %>" maxlength="150" required>
    </div>
    <div class="form-group">
      <label for="description">Description:</label>
      <textarea id="description" name="description" required><%= locals.description || '' %></textarea>
    </div>
    <button type="submit" class="btn-primary">Create Project</button>
  </form>
</main>
<%- include('partials/footer') %>